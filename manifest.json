{
  "manifest_version": 3,
  "name": "Rasco New Tab",
  "version": "1.0",
  "description": "Cyberpunk neon new tab powered by Rasco",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["wallpaper.mp4"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
